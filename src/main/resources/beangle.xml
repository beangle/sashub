<?xml version="1.0"?>
<beangle xmlns="http://beangle.github.io/schema/framework"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://beangle.github.io/schema/framework http://beangle.github.io/schema/framework-1.0.xsd">

  <ems app-name="sas-hub"/>

  <cdi>
    <module class="org.beangle.she.hibernate.OrmModule"/>
    <module class="org.beangle.ems.app.dao.DataSourceModule"/>

    <module class="org.beangle.sashub.web.action.DefaultModule"/>
    <module class="org.beangle.sashub.web.action.config.DefaultModule"/>
    <module class="org.beangle.sashub.web.action.ems.DefaultModule"/>
    <module class="org.beangle.sashub.web.action.micdn.DefaultModule"/>
    <module class="org.beangle.sashub.web.action.monitor.DefaultModule"/>
    <module class="org.beangle.sashub.web.action.repo.DefaultModule"/>
    <module class="org.beangle.sashub.web.ws.DefaultModule"/>
    <module class="org.beangle.sashub.service.DefaultModule"/>
    <module class="org.beangle.webmvc.view.freemarker.DefaultModule"/>

    <module class="org.beangle.ems.app.cas.DefaultModule"/>
    <module class="org.beangle.ems.app.web.DefaultModule"/>
    <module class="org.beangle.ems.app.web.WebReconfigModule"/>
    <module class="org.beangle.ems.app.cache.DefaultModule"/>
    <module class="org.beangle.ems.app.event.EventModule"/>
  </cdi>

  <jpa>
    <mapping class="org.beangle.sashub.model.config.DefaultMapping"/>
    <mapping class="org.beangle.sashub.model.ems.DefaultMapping"/>
    <naming>
      <profile package="org.beangle.sashub.model" pluralize="true" schema="sas">
        <profile package="config"  prefix="cfg_"/>
        <profile package="ems" prefix="ems_"/>
        <profile package="micdn" prefix="cdn_"/>
      </profile>
    </naming>
  </jpa>

  <mvc>
    <profile package="org.beangle.sashub.web.action">
      <url path="/" suffix="" style="seo"/>
      <interceptor name="web.Interceptor.hibernate"/>
      <interceptor name="web.Interceptor.security"/>
    </profile>

    <profile package="org.beangle.sashub.web.action.repo">
      <url path="/repo" suffix="" style="seo"/>
    </profile>

    <profile package="org.beangle.sashub.web.ws.api">
      <action suffix="WS" defaultMethod="index"/>
      <url path="/api/{profile}/" suffix="" style="seo"/>
      <interceptor name="web.Interceptor.hibernate"/>
    </profile>
  </mvc>

</beangle>
